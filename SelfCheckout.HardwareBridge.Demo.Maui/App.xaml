<?xml version="1.0" encoding="UTF-8"?>

<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SelfCheckout.HardwareBridge.Demo.Maui.Converters"
             x:Class="SelfCheckout.HardwareBridge.Demo.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <converters:DeviceStateToColorConverter x:Key="StateToColor" />
            <converters:DeviceStateToDisplayStringConverter x:Key="StateToText" />
            <converters:LogLevelToColorConverter x:Key="LevelToColor" />
        </ResourceDictionary>
    </Application.Resources>
</Application>