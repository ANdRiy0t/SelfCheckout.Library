<?xml version="1.0" encoding="UTF-8"?>

<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:views="clr-namespace:SelfCheckout.HardwareBridge.Demo.Maui.Views"
       x:Class="SelfCheckout.HardwareBridge.Demo.Maui.AppShell"
       Shell.FlyoutBehavior="Disabled"
       Shell.BackgroundColor="{StaticResource Brand}"
       Shell.ForegroundColor="White"
       Shell.TitleColor="White"
       Title="SelfCheckout Demo">
    <TabBar>
        <ShellContent Title="Devices"
                      ContentTemplate="{DataTemplate views:DevicesPage}"
                      Route="DevicesPage" />
        <ShellContent Title="Checkout"
                      ContentTemplate="{DataTemplate views:CheckoutPage}"
                      Route="CheckoutPage" />
        <ShellContent Title="Transports"
                      ContentTemplate="{DataTemplate views:TransportsPage}"
                      Route="TransportsPage" />
    </TabBar>
</Shell>
