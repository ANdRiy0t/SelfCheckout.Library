<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SelfCheckout.HardwareBridge.Demo.Maui.ViewModels"
             x:Class="SelfCheckout.HardwareBridge.Demo.Maui.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Error Injection Settings">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="16">

            <HorizontalStackLayout Spacing="10">
                <BoxView WidthRequest="3"
                         BackgroundColor="{StaticResource BrandAccent}"
                         VerticalOptions="Fill"/>
                <Label Text="Toggle these switches to inject errors into the mock devices at runtime."
                       FontSize="13"
                       TextColor="DimGray"
                       VerticalOptions="Center"
                       HorizontalOptions="FillAndExpand"/>
            </HorizontalStackLayout>

            <!-- Scanner -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Scanner" FontAttributes="Bold" FontSize="16" />
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding ScannerFailOnScan}" />
                    <Label Text="Fail on scan (throw DeviceException)" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding ScannerSimulateDisconnect}" />
                    <Label Text="Simulate disconnect on scan" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#E2E8F0"/>

            <!-- Scale -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Scale" FontAttributes="Bold" FontSize="16" />
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding ScaleFailOnRead}" />
                    <Label Text="Fail on weight read (throw DeviceException)" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#E2E8F0"/>

            <!-- Terminal -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Payment Terminal" FontAttributes="Bold" FontSize="16" />
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding TerminalShouldDecline}" />
                    <Label Text="Decline payment (PaymentResult.IsApproved=false)" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding TerminalShouldFailOnProcess}" />
                    <Label Text="Fail on process (throw DeviceException)" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding TerminalSimulateDisconnect}" />
                    <Label Text="Simulate disconnect on process" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" BackgroundColor="#E2E8F0"/>

            <!-- Printer -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Printer" FontAttributes="Bold" FontSize="16" />
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding PrinterShouldFail}" />
                    <Label Text="Fail on print (throw DeviceException)" VerticalOptions="Center" />
                </HorizontalStackLayout>
                <HorizontalStackLayout Spacing="10">
                    <Switch IsToggled="{Binding PrinterSimulateOutOfPaper}" />
                    <Label Text="Simulate out of paper (Error state)" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <Button Text="Close" Command="{Binding CloseCommand}" HorizontalOptions="Start" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
